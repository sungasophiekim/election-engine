# Election Strategy Engine — 환경 변수
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 네이버 뉴스 검색 API (데이터 수집용)
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# YouTube Data API v3 (유튜브 수집용, 선택사항)
# 발급: https://console.cloud.google.com → API → YouTube Data API v3 활성화 → 인증정보
YOUTUBE_API_KEY=

# Instagram Graph API (선택사항 — 비즈니스 계정 필요)
# 연동 방법:
#   1. 인스타 비즈니스/크리에이터 계정으로 전환
#   2. https://developers.facebook.com → 앱 생성
#   3. Instagram Graph API 추가 → 페이스북 페이지 연결
#   4. 장기 액세스 토큰 생성
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
INSTAGRAM_USERNAME=

# 슬랙 웹훅 (위기 알림)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# 운영 환경
ENV=development   # development | production
